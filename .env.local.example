# ============================================================
# AGROFACTURAS / FacturIA — Variables de entorno
# Copiar como .env.local y rellenar con tus valores reales
# ============================================================

# --- Supabase (Fase 1+) ---
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu-anon-key

# --- Google Gemini (Fase 2+) ---
# Si solo tienes una key, deja la secundaria vacía
GEMINI_API_KEY_PRIMARY=tu-key-primaria
GEMINI_API_KEY_SECONDARY=tu-key-secundaria
